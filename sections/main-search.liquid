<section class="mr-page">
  <div class="mr-page__container">
    <h1 class="mr-page__title">Búsqueda</h1>
    <form action="/search" method="get">
      <input type="search" name="q" value="{{ search.terms | escape }}" class="mr-newsletter__input" placeholder="Buscar productos..." style="width:100%; margin-bottom:30px;">
    </form>
    {% if search.results.size > 0 %}
      <div class="mr-products__grid">
        {% for item in search.results %}
          <a href="{{ item.url }}" class="mr-product">
            <div class="mr-product__media">
              {{ 'product-apparel-1' | placeholder_svg_tag: 'mr-product__svg' }}
            </div>
            <h3 class="mr-product__title">{{ item.title }}</h3>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Búsqueda",
  "settings": []
}
{% endschema %}
