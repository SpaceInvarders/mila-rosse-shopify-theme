<section class="mr-intro">
  <div class="mr-intro__eyebrow">{{ section.settings.eyebrow }}</div>
  <h2 class="mr-intro__title">{{ section.settings.title }}</h2>
  <div class="mr-intro__divider"></div>
  <p class="mr-intro__text">{{ section.settings.text }}</p>
</section>

{% schema %}
{
  "name": "Intro Texto",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (texto superior)",
      "default": "LOOKBOOK"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Piezas Destacadas"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Descripción",
      "default": "Descubre nuestras creaciones más emblemáticas, diseñadas con tejidos premium y atención al detalle en cada costura."
    }
  ],
  "presets": [
    {
      "name": "Intro Texto"
    }
  ]
}
{% endschema %}
