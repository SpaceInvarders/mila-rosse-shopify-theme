{% comment %}
  Mila Rosse - V3 Harumi Style Product Section
  - Stacked Desktop / Carousel Mobile
  - Sticky info panel
  - Minimalist uncolored aesthetic stars
  - Trust icons
  - Accordions
  - Recommendations
{% endcomment %}

<style>
  :root {
    --mr-cream: #FBF9F6;
    --mr-green: #1B4D3E;
    --mr-border: rgba(27, 77, 62, 0.15);
    --mr-font-serif: 'Playfair Display', serif;
    --mr-font-sans: 'Inter', sans-serif;
  }

  .mr-product-harumi {
    background-color: var(--mr-cream);
    color: var(--mr-green);
    font-family: var(--mr-font-sans);
    padding: 0;
    margin: 0;
  }

  .mr-product-harumi__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
    display: grid;
    grid-template-columns: 60% 40%;
    gap: 3rem;
  }

  /* MEDIA GALLERY (Desktop) */
  .mr-gallery {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .mr-gallery img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 4px;
    background: #f1ede6;
  }

  /* PRODUCT INFO (Sticky Desktop) */
  .mr-info-wrapper {
    position: sticky;
    top: 2rem;
    align-self: start;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    padding-right: 15px;
    padding-bottom: 2rem;
    scrollbar-width: thin;
    scrollbar-color: var(--mr-border) transparent;
  }
  .mr-info-wrapper::-webkit-scrollbar {
    width: 4px;
  }
  .mr-info-wrapper::-webkit-scrollbar-thumb {
    background-color: var(--mr-border);
    border-radius: 4px;
  }

  /* Minimalism aesthetic stars */
  .mr-aesthetic-stars {
    display: inline-flex;
    gap: 3px;
    margin-bottom: 1rem;
    align-items: center;
  }
  .mr-aesthetic-stars svg {
    width: 15px;
    height: 15px;
    fill: none;
    stroke: var(--mr-green);
    stroke-width: 1.5;
  }
  .mr-review-count {
    font-size: 0.8rem;
    margin-left: 6px;
    letter-spacing: 1px;
    opacity: 0.8;
  }

  /* Typography */
  .mr-product-title {
    font-family: var(--mr-font-serif);
    font-size: clamp(2rem, 3vw, 2.8rem);
    margin: 0 0 0.5rem 0;
    color: var(--mr-green);
    line-height: 1.1;
    font-weight: 400;
  }

  .mr-product-price {
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 2rem;
    font-family: var(--mr-font-serif);
  }

  /* Form & Variants */
  .mr-variant-selector {
    margin-bottom: 2rem;
  }
  .mr-variant-label {
    font-weight: 400;
    margin-bottom: 0.5rem;
    display: block;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 1px;
    opacity: 0.8;
  }
  .mr-variant-select {
    width: 100%;
    padding: 12px;
    border: 1px solid var(--mr-border);
    background: transparent;
    font-family: inherit;
    color: var(--mr-green);
    border-radius: 0;
    appearance: none;
  }

  /* Buttons */
  .mr-btn {
    width: 100%;
    background-color: var(--mr-green);
    color: #fff;
    border: 1px solid var(--mr-green);
    padding: 1.1rem;
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.3s;
    border-radius: 2px;
    margin-bottom: 1.5rem;
  }
  .mr-btn:hover {
    background-color: transparent;
    color: var(--mr-green);
  }

  /* Trust Icons */
  .mr-trust-icons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .mr-trust-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .mr-trust-item svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: var(--mr-green);
    stroke-width: 1.5;
  }

  /* Accordions */
  .mr-accordions {
    border-top: 1px solid var(--mr-border);
    margin-bottom: 3rem;
  }
  .mr-accordion {
    border-bottom: 1px solid var(--mr-border);
  }
  .mr-accordion summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 0;
    cursor: pointer;
    font-family: var(--mr-font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    list-style: none;
    color: var(--mr-green);
  }
  .mr-accordion summary::-webkit-details-marker {
    display: none;
  }
  .mr-accordion summary::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 300;
    transition: transform 0.3s ease;
  }
  .mr-accordion[open] summary::after {
    transform: rotate(45deg);
  }
  .mr-accordion-content {
    padding-bottom: 1.5rem;
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(27, 77, 62, 0.8);
  }

  /* Review Minimalist UI / Testimonials */
  .mr-pdp__testimonials {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--mr-border);
    font-family: 'Inter', sans-serif;
  }
  .mr-pdp__testimonials-title {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--mr-text, #1a1a1a);
    margin: 0 0 15px;
  }
  .mr-pdp__testimonials-summary {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 20px;
  }
  .mr-pdp__testimonials-stars {
    display: flex;
    align-items: center;
    color: var(--mr-copper, #c97a44);
    font-size: 1.2rem;
    margin-bottom: 5px;
  }
  .mr-pdp__testimonials-stars .half { opacity: 0.5; }
  .mr-pdp__testimonials-score {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--mr-text-light, #666);
    margin-left: 10px;
  }
  .mr-pdp__testimonials-count {
    font-size: 0.75rem;
    color: var(--mr-text-light, #666);
    margin: 0;
  }
  .mr-pdp__testimonials-bars {
    max-width: 320px;
    margin: 0 auto 30px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mr-pdp__testimonials-bar-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.75rem;
    color: var(--mr-text-light, #666);
  }
  .mr-pdp__testimonials-bar-stars {
    color: var(--mr-copper, #c97a44);
    width: 60px;
    text-align: right;
    letter-spacing: 2px;
  }
  .mr-pdp__testimonials-bar-stars .empty { color: var(--mr-border, #e8e4de); }
  .mr-pdp__testimonials-bar-track {
    flex: 1;
    height: 8px;
    background: var(--mr-cream, #faf8f6);
    border-radius: 4px;
    overflow: hidden;
  }
  .mr-pdp__testimonials-bar-fill {
    height: 100%;
    background: var(--mr-dark-green, #1a472a);
    border-radius: 4px;
  }
  .mr-pdp__testimonials-bar-count {
    width: 30px;
    text-align: left;
  }
  .mr-pdp__testimonials-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 20px;
  }
  .mr-pdp__testimonials-btn {
    width: 100%;
    padding: 12px;
    border-radius: 30px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .mr-pdp__testimonials-btn--dark {
    background: #333333;
    color: #ffffff;
    border: none;
  }
  .mr-pdp__testimonials-btn--dark:hover { background: #000000; }
  .mr-pdp__testimonials-btn--light {
    background: #ffffff;
    color: var(--mr-text-light, #666);
    border: 1px solid var(--mr-border, #e8e4de);
  }
  .mr-pdp__testimonials-btn--light:hover { background: var(--mr-cream, #faf8f6); }

  /* Related Products */
  .mr-related-section {
    border-top: 1px solid var(--mr-border);
    margin-top: 2rem;
    padding: 5rem 2rem;
    background-color: #fff;
  }
  .mr-related-title {
    font-family: var(--mr-font-serif);
    font-size: 2rem;
    text-align: center;
    margin-bottom: 3rem;
    font-weight: 400;
    color: var(--mr-green);
  }
  .mr-related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .mr-related-product {
    text-decoration: none;
    color: var(--mr-green);
    group;
  }
  .mr-related-img-wrap {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    margin-bottom: 1.2rem;
    background: #f1ede6;
  }
  .mr-related-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .mr-related-product:hover .mr-related-img-wrap img {
    transform: scale(1.04);
  }
  .mr-related-info h4 {
    font-family: var(--mr-font-sans);
    font-weight: 400;
    font-size: 0.95rem;
    margin: 0 0 0.4rem 0;
  }
  .mr-related-info .price {
    font-family: var(--mr-font-serif);
    font-weight: 400;
    font-size: 1.1rem;
  }

  /* MOBILE RESPONSIVE */
  @media screen and (max-width: 989px) {
    .mr-product-harumi__container {
      grid-template-columns: 1fr;
      padding: 0;
      gap: 0;
    }
    
    .mr-gallery {
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }
    .mr-gallery::-webkit-scrollbar {
      display: none;
    }
    .mr-gallery img {
      width: 100vw;
      flex-shrink: 0;
      scroll-snap-align: start;
      border-radius: 0;
    }
    
    .mr-info-wrapper {
      position: relative;
      top: 0;
      max-height: none;
      padding: 2.5rem 1.5rem;
      overflow: visible;
    }
    
    .mr-related-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .mr-related-section {
      padding: 4rem 1.5rem;
    }
  }
</style>

<div class="mr-product-harumi">
  <div class="mr-product-harumi__container">
    
    <!-- LEFT: GALLERY -->
    <div class="mr-gallery">
      {% for media in product.media %}
        {% if media.media_type == 'image' %}
          <img src="{{ media | image_url: width: 1200 }}" alt="{{ media.alt | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        {% endif %}
      {% endfor %}
    </div>

    <!-- RIGHT: PRODUCT INFO -->
    <div class="mr-info-wrapper">
      
      <!-- Minimalist Rating -->
      <div class="mr-aesthetic-stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {%- endfor -%}
        <span class="mr-review-count">4.9 / 5 (Reseñas comprobadas)</span>
      </div>

      <h1 class="mr-product-title">{{ product.title }}</h1>
      <div class="mr-product-price">{{ product.price | money }}</div>

      <!-- Add to Cart Form -->
      {%- form 'product', product, id: 'product-form-harumi', class: 'form' -%}
        {% unless product.has_only_default_variant %}
          <div class="mr-variant-selector">
            {% for option in product.options_with_values %}
              <label class="mr-variant-label">{{ option.name }}</label>
              <select name="options[{{ option.name | escape }}]" class="mr-variant-select">
                {% for value in option.values %}
                  <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
                    {{ value }}
                  </option>
                {% endfor %}
              </select>
            {% endfor %}
          </div>
        {% endunless %}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        <button type="submit" name="add" class="mr-btn" {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
          {% if product.selected_or_first_available_variant.available %}
            Añadir a la bolsa
          {% else %}
            Agotado
          {% endif %}
        </button>
      {%- endform -%}

      <!-- Trust Sidebar Icons (Minimalist stroke SVG) -->
      <div class="mr-trust-icons">
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <span>En existencias, listo para enviar</span>
        </div>
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <span>Pago 100% encriptado y seguro</span>
        </div>
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>
          <span>Facturación electrónica disponible</span>
        </div>
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          <span>Envíos Rápidos en 48 horas</span>
        </div>
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"></polyline><polyline points="23 20 23 14 17 14"></polyline><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"></path></svg>
          <span>Política de Devolución extendida</span>
        </div>
      </div>

      <!-- Accordions -->
      <div class="mr-accordions">
        <details class="mr-accordion" open>
          <summary>Descripción del Producto</summary>
          <div class="mr-accordion-content">
            {% if product.description != blank %}
              {{ product.description }}
            {% else %}
              <p>Un artículo de sastrería excepcional, diseñado meticulosamente para la mujer contemporánea. Confeccionado con técnicas artesanales y los mejores materiales del mercado para garantizar durabilidad, estructura y un ajuste sencillamente impecable.</p>
            {% endif %}
          </div>
        </details>
        
        <details class="mr-accordion">
          <summary>Modo de Uso & Estilismo</summary>
          <div class="mr-accordion-content">
            <p>Ideal para elevar cualquier conjunto. Combínalo con pantalones de pinzas para un look corporativo imponente, o úsalo sobre unos jeans ajustados para un estilo casual-chic. El balance perfecto entre lo formal y lo versátil.</p>
          </div>
        </details>

        <details class="mr-accordion">
          <summary>Recomendado para (Tipo de silueta)</summary>
          <div class="mr-accordion-content">
            <p>Gracias a su corte estructurado y proporciones estudiadas, favorece y equilibra la figura, aportando elegancia y definiendo sutilmente las líneas del cuerpo femenino sin sacrificar comodidad.</p>
          </div>
        </details>

        <details class="mr-accordion">
          <summary>Composición & Forro</summary>
          <div class="mr-accordion-content">
            <p>Tejido exterior premium seleccionado cuidadosamente. Forro interno de alta transpirabilidad (fibras que no generan estática) diseñado para acariciar la piel y aportar estructura interna.</p>
          </div>
        </details>

        <details class="mr-accordion">
          <summary>Alertas & Cuidados Especiales</summary>
          <div class="mr-accordion-content">
            <p>Recomendamos limpieza en seco únicamente. No usar lejía ni secadora. Planchar a baja temperatura utilizando un paño protector de algodón. Guardar siempre en percha estructurada para mantener la forma intacta.</p>
          </div>
        </details>
      </div>

      <!-- Minimalist Review UI / Testimonials -->
      <div class="mr-pdp__testimonials">
        <h4 class="mr-pdp__testimonials-title">Testimonios de nuestros clientes</h4>
        <div class="mr-pdp__testimonials-summary">
          <div class="mr-pdp__testimonials-stars">
            <span>★</span><span>★</span><span>★</span><span>★</span><span class="half">★</span>
            <span class="mr-pdp__testimonials-score">4.66 de 5</span>
          </div>
          <p class="mr-pdp__testimonials-count">Basado en 458 reseñas(s)</p>
        </div>

        <div class="mr-pdp__testimonials-bars">
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★★★★★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 80%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">379</span>
          </div>
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★★★★</span><span class="empty">★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 15%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">40</span>
          </div>
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★★★</span><span class="empty">★★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 5%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">17</span>
          </div>
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★★</span><span class="empty">★★★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 2%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">7</span>
          </div>
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★</span><span class="empty">★★★★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 4%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">15</span>
          </div>
        </div>

        <div class="mr-pdp__testimonials-actions">
          <button class="mr-pdp__testimonials-btn mr-pdp__testimonials-btn--dark">Escribir una reseña</button>
          <button class="mr-pdp__testimonials-btn mr-pdp__testimonials-btn--light">Tengo una pregunta</button>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Related Products -->
<div class="mr-related-section">
  <h2 class="mr-related-title">Más para descubrir</h2>
  
  <product-recommendations class="mr-related-grid" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=4">
    {%- if recommendations.performed and recommendations.products_count > 0 -%}
      {% for recommendation in recommendations.products limit: 4 %}
        <a href="{{ recommendation.url }}" class="mr-related-product">
          <div class="mr-related-img-wrap">
            <img src="{{ recommendation.featured_media | image_url: width: 600 }}" alt="{{ recommendation.title | escape }}" loading="lazy">
          </div>
          <div class="mr-related-info">
            <h4>{{ recommendation.title }}</h4>
            <div class="price">{{ recommendation.price | money }}</div>
          </div>
        </a>
      {% endfor %}
    {%- endif -%}
  </product-recommendations>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Native Shopify related products script fetcher
    const handleRecommendations = () => {
      const recommendationsContainer = document.querySelector('product-recommendations');
      if (!recommendationsContainer) return;
      
      fetch(recommendationsContainer.dataset.url)
        .then(response => response.text())
        .then(text => {
          const html = document.createElement('div');
          html.innerHTML = text;
          const recommendations = html.querySelector('product-recommendations');
          
          if (recommendations && recommendations.innerHTML.trim().length) {
            recommendationsContainer.innerHTML = recommendations.innerHTML;
          }
        })
        .catch(e => {
          console.error('Error fetching recommendations:', e);
        });
    };
    handleRecommendations();
  });
</script>

{% schema %}
{
  "name": "Producto Harumi",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Producto Harumi V3"
    }
  ]
}
{% endschema %}
