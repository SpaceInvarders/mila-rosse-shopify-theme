<section class="mr-pdp">
  <div class="mr-pdp__container">

    <div class="mr-pdp__gallery">
      {%- if product.images.size > 0 -%}
        <div class="mr-pdp__main-image">
          <img
            id="MainImage-{{ section.id }}"
            src="{{ product.featured_image | image_url: width: 1200 }}"
            alt="{{ product.featured_image.alt | escape | default: product.title }}"
            loading="eager"
            width="600"
            height="780">
        </div>

        {%- if product.images.size > 1 -%}
          <div class="mr-pdp__thumbs">
            {%- for image in product.images -%}
              <button
                type="button"
                class="mr-pdp__thumb {% if forloop.first %}mr-pdp__thumb--active{% endif %}"
                data-image-url="{{ image | image_url: width: 1200 }}"
                aria-label="Ver imagen {{ forloop.index }}">
                <img
                  src="{{ image | image_url: width: 200 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  loading="lazy"
                  width="100"
                  height="130">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="mr-pdp__main-image mr-pdp__main-image--placeholder">
          {{ 'product-apparel-1' | placeholder_svg_tag: 'mr-pdp__placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="mr-pdp__info">
      {%- if product.type != blank -%}
        <div class="mr-pdp__category">{{ product.type }}</div>
      {%- endif -%}

      <h1 class="mr-pdp__title">{{ product.title }}</h1>

      <div class="mr-pdp__price">
        {%- if product.compare_at_price > product.price -%}
          <span class="mr-pdp__price-sale">{{ product.price | money }}</span>
          <span class="mr-pdp__price-compare">{{ product.compare_at_price | money }}</span>
        {%- else -%}
          <span class="mr-pdp__price-current">{{ product.price | money }}</span>
        {%- endif -%}
      </div>

      <div class="mr-pdp__divider"></div>

      {%- form 'product', product, id: 'ProductForm', class: 'mr-pdp__form' -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="mr-pdp__option">
              <label class="mr-pdp__option-label">{{ option.name }}</label>
              <div class="mr-pdp__option-values">
                {%- for value in option.values -%}
                  <label class="mr-pdp__option-pill {% if option.selected_value == value %}mr-pdp__option-pill--active{% endif %}">
                    <input
                      type="radio"
                      name="options[{{ option.name }}]"
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}checked{% endif %}
                      hidden>
                    <span>{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <button
          type="submit"
          name="add"
          class="mr-pdp__add-to-cart {% unless product.selected_or_first_available_variant.available %}mr-pdp__add-to-cart--disabled{% endunless %}"
          {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
          {%- if product.selected_or_first_available_variant.available -%}
            Agregar al Carrito
          {%- else -%}
            Agotado
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- if product.description != blank -%}
        <div class="mr-pdp__description">
          <h2 class="mr-pdp__description-title">Descripción</h2>
          <div class="mr-pdp__description-content">{{ product.description }}</div>
        </div>
      {%- endif -%}

      <div class="mr-pdp__features">
        <div class="mr-pdp__feature">
          <strong>Envío Gratis</strong>
          <span>En compras sobre $300.000</span>
        </div>
        <div class="mr-pdp__feature">
          <strong>Cambios</strong>
          <span>30 días para cambios</span>
        </div>
        <div class="mr-pdp__feature">
          <strong>Asesoría</strong>
          <span><a href="https://wa.me/{{ settings.whatsapp_number | default: '573227786365' }}" target="_blank" rel="noopener">WhatsApp directo</a></span>
        </div>
      </div>

      <div class="mr-pdp__testimonials">
        <h4 class="mr-pdp__testimonials-title">Testimonios de nuestros clientes</h4>
        <div class="mr-pdp__testimonials-summary">
          <div class="mr-pdp__testimonials-stars">
            <span>★</span><span>★</span><span>★</span><span>★</span><span class="half">★</span>
            <span class="mr-pdp__testimonials-score">4.66 de 5</span>
          </div>
          <p class="mr-pdp__testimonials-count">Basado en 458 reseñas(s)</p>
        </div>

        <div class="mr-pdp__testimonials-bars">
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★★★★★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 80%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">379</span>
          </div>
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★★★★</span><span class="empty">★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 15%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">40</span>
          </div>
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★★★</span><span class="empty">★★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 5%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">17</span>
          </div>
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★★</span><span class="empty">★★★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 2%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">7</span>
          </div>
          <div class="mr-pdp__testimonials-bar-row">
            <div class="mr-pdp__testimonials-bar-stars"><span>★</span><span class="empty">★★★★</span></div>
            <div class="mr-pdp__testimonials-bar-track"><div class="mr-pdp__testimonials-bar-fill" style="width: 4%"></div></div>
            <span class="mr-pdp__testimonials-bar-count">15</span>
          </div>
        </div>

        <div class="mr-pdp__testimonials-actions">
          <button class="mr-pdp__testimonials-btn mr-pdp__testimonials-btn--dark">Escribir una reseña</button>
          <button class="mr-pdp__testimonials-btn mr-pdp__testimonials-btn--light">Tengo una pregunta</button>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .mr-pdp {
    background: var(--mr-white, #ffffff);
    padding: 60px 30px;
  }
  .mr-pdp__container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .mr-pdp__gallery {
    position: sticky;
    top: 100px;
  }
  .mr-pdp__main-image {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--mr-cream, #faf8f6);
    margin-bottom: 15px;
  }
  .mr-pdp__main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }
  .mr-pdp__main-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px;
  }
  .mr-pdp__placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }
  .mr-pdp__thumbs {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 10px;
  }
  .mr-pdp__thumb {
    aspect-ratio: 3/4;
    background: var(--mr-cream, #faf8f6);
    border: 1px solid transparent;
    cursor: pointer;
    padding: 0;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }
  .mr-pdp__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .mr-pdp__thumb:hover { border-color: var(--mr-copper, #c97a44); }
  .mr-pdp__thumb--active { border-color: var(--mr-dark-green, #1a472a); border-width: 2px; }

  .mr-pdp__info { padding-top: 10px; }
  .mr-pdp__category {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--mr-copper, #c97a44);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 15px;
    font-weight: 500;
  }
  .mr-pdp__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--mr-dark-green, #1a472a);
    margin: 0 0 25px;
    line-height: 1.2;
    text-transform: none;
  }
  .mr-pdp__price {
    font-family: 'Inter', sans-serif;
    font-size: 1.4rem;
    color: var(--mr-dark-green, #1a472a);
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: 25px;
  }
  .mr-pdp__price-sale { color: var(--mr-copper, #c97a44); margin-right: 12px; }
  .mr-pdp__price-compare { text-decoration: line-through; opacity: 0.5; font-size: 1rem; }
  .mr-pdp__divider {
    width: 60px;
    height: 1px;
    background: var(--mr-copper, #c97a44);
    margin: 0 0 35px;
  }

  .mr-pdp__form { display: block; }
  .mr-pdp__option { margin-bottom: 25px; }
  .mr-pdp__option-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: 12px;
    color: var(--mr-text, #1a1a1a);
    font-weight: 500;
  }
  .mr-pdp__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .mr-pdp__option-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 50px;
    padding: 12px 20px;
    border: 1px solid var(--mr-border, #e8e4de);
    background: transparent;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s ease;
    user-select: none;
  }
  .mr-pdp__option-pill:hover {
    border-color: var(--mr-dark-green, #1a472a);
  }
  .mr-pdp__option-pill--active {
    background: var(--mr-dark-green, #1a472a);
    color: var(--mr-white, #ffffff);
    border-color: var(--mr-dark-green, #1a472a);
  }

  .mr-pdp__add-to-cart {
    width: 100%;
    padding: 18px 30px;
    background: var(--mr-dark-green, #1a472a);
    color: var(--mr-white, #ffffff);
    border: 1px solid var(--mr-dark-green, #1a472a);
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 15px;
  }
  .mr-pdp__add-to-cart:hover {
    background: transparent;
    color: var(--mr-dark-green, #1a472a);
  }
  .mr-pdp__add-to-cart--disabled {
    background: var(--mr-border, #e8e4de);
    border-color: var(--mr-border, #e8e4de);
    color: var(--mr-text-light, #666);
    cursor: not-allowed;
  }
  .mr-pdp__add-to-cart--disabled:hover {
    background: var(--mr-border, #e8e4de);
    color: var(--mr-text-light, #666);
  }

  .mr-pdp__description {
    margin-top: 50px;
    padding-top: 30px;
    border-top: 1px solid var(--mr-border, #e8e4de);
  }
  .mr-pdp__description-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mr-dark-green, #1a472a);
    margin: 0 0 20px;
  }
  .mr-pdp__description-content {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--mr-text, #1a1a1a);
  }
  .mr-pdp__description-content ul {
    padding-left: 20px;
    margin: 15px 0;
  }
  .mr-pdp__description-content li {
    margin-bottom: 8px;
  }
  .mr-pdp__description-content strong {
    color: var(--mr-dark-green, #1a472a);
  }

  .mr-pdp__features {
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid var(--mr-border, #e8e4de);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .mr-pdp__feature {
    text-align: center;
    font-family: 'Inter', sans-serif;
  }
  .mr-pdp__feature strong {
    display: block;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mr-dark-green, #1a472a);
    margin-bottom: 5px;
  }
  .mr-pdp__feature span {
    font-size: 0.8rem;
    color: var(--mr-text-light, #666);
  }
  .mr-pdp__feature a {
    color: var(--mr-copper, #c97a44);
    text-decoration: none;
  }
  .mr-pdp__feature a:hover { text-decoration: underline; }

  /* Testimonials */
  .mr-pdp__testimonials {
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid var(--mr-border, #e8e4de);
    font-family: 'Inter', sans-serif;
  }
  .mr-pdp__testimonials-title {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--mr-text, #1a1a1a);
    margin: 0 0 15px;
  }
  .mr-pdp__testimonials-summary {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 20px;
  }
  .mr-pdp__testimonials-stars {
    display: flex;
    align-items: center;
    color: var(--mr-copper, #c97a44);
    font-size: 1.2rem;
    margin-bottom: 5px;
  }
  .mr-pdp__testimonials-stars .half { opacity: 0.5; }
  .mr-pdp__testimonials-score {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--mr-text-light, #666);
    margin-left: 10px;
  }
  .mr-pdp__testimonials-count {
    font-size: 0.75rem;
    color: var(--mr-text-light, #666);
    margin: 0;
  }
  .mr-pdp__testimonials-bars {
    max-width: 320px;
    margin: 0 auto 30px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mr-pdp__testimonials-bar-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.75rem;
    color: var(--mr-text-light, #666);
  }
  .mr-pdp__testimonials-bar-stars {
    color: var(--mr-copper, #c97a44);
    width: 60px;
    text-align: right;
    letter-spacing: 2px;
  }
  .mr-pdp__testimonials-bar-stars .empty { color: var(--mr-border, #e8e4de); }
  .mr-pdp__testimonials-bar-track {
    flex: 1;
    height: 8px;
    background: var(--mr-cream, #faf8f6);
    border-radius: 4px;
    overflow: hidden;
  }
  .mr-pdp__testimonials-bar-fill {
    height: 100%;
    background: var(--mr-dark-green, #1a472a);
    border-radius: 4px;
  }
  .mr-pdp__testimonials-bar-count {
    width: 30px;
    text-align: left;
  }
  .mr-pdp__testimonials-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 20px;
  }
  .mr-pdp__testimonials-btn {
    width: 100%;
    padding: 12px;
    border-radius: 30px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .mr-pdp__testimonials-btn--dark {
    background: #333333;
    color: #ffffff;
    border: none;
  }
  .mr-pdp__testimonials-btn--dark:hover { background: #000000; }
  .mr-pdp__testimonials-btn--light {
    background: #ffffff;
    color: var(--mr-text-light, #666);
    border: 1px solid var(--mr-border, #e8e4de);
  }
  .mr-pdp__testimonials-btn--light:hover { background: var(--mr-cream, #faf8f6); }

  @media (max-width: 768px) {
    .mr-pdp { padding: 30px 20px; }
    .mr-pdp__container { grid-template-columns: 1fr; gap: 30px; }
    .mr-pdp__gallery { position: static; }
    .mr-pdp__thumbs { grid-template-columns: repeat(4, 1fr); }
    .mr-pdp__features { grid-template-columns: 1fr; gap: 15px; }
  }
</style>

<script>
(function() {
  var mainImage = document.getElementById('MainImage-{{ section.id }}');
  var thumbs = document.querySelectorAll('.mr-pdp__thumb');
  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var url = this.dataset.imageUrl;
      if (mainImage && url) {
        mainImage.src = url;
        thumbs.forEach(function(t) { t.classList.remove('mr-pdp__thumb--active'); });
        this.classList.add('mr-pdp__thumb--active');
      }
    });
  });

  var pills = document.querySelectorAll('.mr-pdp__option-pill');
  pills.forEach(function(pill) {
    pill.addEventListener('click', function() {
      var parent = this.parentElement;
      parent.querySelectorAll('.mr-pdp__option-pill').forEach(function(p) {
        p.classList.remove('mr-pdp__option-pill--active');
      });
      this.classList.add('mr-pdp__option-pill--active');
    });
  });
})();
</script>

{% schema %}
{
  "name": "Producto",
  "settings": []
}
{% endschema %}
