{% comment %}
  Mila Rosse – Sección de Videos de Instagram
  Muestra hasta 5 videos de Instagram en un scroll horizontal deslizable
{% endcomment %}

{%- style -%}
  .mr-instagram-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .mr-instagram-header {
    text-align: center;
    margin-bottom: 2rem;
    padding: 0 1.5rem;
  }

  .mr-instagram-label {
    font-size: 0.8rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #1B4D3E;
    display: block;
    margin-bottom: 0.5rem;
    font-family: 'Inter', sans-serif;
  }

  .mr-instagram-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    color: #1B4D3E;
    margin: 0 0 0.5rem 0;
    font-weight: 400;
  }

  .mr-instagram-subtext {
    color: #666;
    font-size: 0.95rem;
    margin: 0;
  }

  /* Scroll horizontal */
  .mr-instagram-track-wrapper {
    position: relative;
    overflow: hidden;
  }

  .mr-instagram-track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 2rem 1rem;
  }

  .mr-instagram-track::-webkit-scrollbar {
    display: none;
  }

  /* Cada video card */
  .mr-insta-card {
    flex: 0 0 300px;
    scroll-snap-align: start;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    position: relative;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .mr-insta-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
  }

  .mr-insta-card iframe,
  .mr-insta-card video {
    width: 100%;
    aspect-ratio: 9/16;
    border: none;
    display: block;
  }

  /* Overlay con ícono de Instagram */
  .mr-insta-overlay {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .mr-insta-overlay svg {
    width: 20px;
    height: 20px;
    fill: #fff;
  }

  /* Flechas de navegación */
  .mr-insta-nav {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .mr-insta-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid #1B4D3E;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s;
    color: #1B4D3E;
  }

  .mr-insta-arrow:hover {
    background: #1B4D3E;
    color: #fff;
  }

  .mr-insta-arrow svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* CTA */
  .mr-instagram-cta {
    text-align: center;
    margin-top: 2rem;
  }

  .mr-instagram-cta a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #1B4D3E;
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 600;
    border-bottom: 1.5px solid #1B4D3E;
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }

  .mr-instagram-cta a:hover {
    opacity: 0.65;
  }

  @media screen and (max-width: 749px) {
    .mr-insta-card {
      flex: 0 0 75vw;
    }
    .mr-instagram-section {
      padding: calc({{ section.settings.padding_top }}px * 0.6) 0 calc({{ section.settings.padding_bottom }}px * 0.6);
    }
  }
{%- endstyle -%}

<div class="mr-instagram-section">
  {%- if section.settings.heading != blank or section.settings.subtext != blank -%}
    <div class="mr-instagram-header">
      {%- if section.settings.label != blank -%}
        <span class="mr-instagram-label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="mr-instagram-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="mr-instagram-subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="mr-instagram-track-wrapper">
    <div class="mr-instagram-track" id="mr-insta-track-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'video' and block.settings.embed_url != blank -%}
          <div class="mr-insta-card" {{ block.shopify_attributes }}>
            <iframe
              src="{{ block.settings.embed_url }}"
              allowfullscreen
              scrolling="no"
              allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
              loading="lazy"
            ></iframe>
            <div class="mr-insta-overlay">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.blocks.size > 2 -%}
    <div class="mr-insta-nav">
      <button class="mr-insta-arrow" id="mr-insta-prev-{{ section.id }}" aria-label="Anterior">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="mr-insta-arrow" id="mr-insta-next-{{ section.id }}" aria-label="Siguiente">
        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  {%- endif -%}

  {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
    <div class="mr-instagram-cta">
      <a href="{{ section.settings.cta_url }}" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#1B4D3E">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        {{ section.settings.cta_label }}
      </a>
    </div>
  {%- endif -%}
</div>

<script>
  (function() {
    const track = document.getElementById('mr-insta-track-{{ section.id }}');
    const prev  = document.getElementById('mr-insta-prev-{{ section.id }}');
    const next  = document.getElementById('mr-insta-next-{{ section.id }}');
    if (!track) return;

    const cardWidth = () => {
      const card = track.querySelector('.mr-insta-card');
      return card ? card.offsetWidth + 16 : 316; // card + gap
    };

    if (prev) prev.addEventListener('click', () => track.scrollBy({ left: -cardWidth(), behavior: 'smooth' }));
    if (next) next.addEventListener('click', () => track.scrollBy({ left:  cardWidth(), behavior: 'smooth' }));
  })();
</script>

{% schema %}
{
  "name": "Instagram Videos",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta superior",
      "default": "SÍGUENOS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Como lo usan nuestras clientas"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtítulo",
      "default": "Videos reales · Sin filtros · Pura sastrería"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#FBF9F6"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón CTA",
      "default": "Seguir en Instagram"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link del botón CTA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Espacio superior",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Espacio inferior",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video de Instagram",
      "settings": [
        {
          "type": "text",
          "id": "embed_url",
          "label": "URL del embed de Instagram",
          "info": "Pega aquí la URL que obtienes al hacer clic en 'Compartir > Insertar' en Instagram (ej: https://www.instagram.com/reel/xxxxx/embed)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Videos",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
