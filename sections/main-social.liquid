      "default": "Chaquetilla Manchester Classic"
    },
    {
      "type": "textarea",
      "id": "reel_2_description",
      "label": "Descripcion",
      "default": "La chaquetilla que marca tendencia. Diseño moderno y versatil."
    },
    {
      "type": "header",
      "content": "Reel 3"
    },
    {
      "type": "text",
      "id": "reel_3_url",
      "label": "URL Embed Instagram",
      "default": "https://www.instagram.com/p/DY7eRBpxC0S/embed/"
    },
    {
      "type": "text",
      "id": "reel_3_title",
      "label": "Titulo",
      "default": "Diseño Oversize Sofisticado"
    },
    {
      "type": "textarea",
      "id": "reel_3_description",
      "label": "Descripcion",
      "default": "La prenda perfecta para un estilo moderno y con personalidad."
    },
    {
      "type": "header",
      "content": "Reel 4"
    },
    {
      "type": "text",
      "id": "reel_4_url",
      "label": "URL Embed Instagram",
      "default": "https://www.instagram.com/p/DPm_e6yEeyM/embed/"
    },
    {
      "type": "text",
      "id": "reel_4_title",
      "label": "Titulo",
      "default": "Blazers de Temporada"
    },
    {
      "type": "textarea",
      "id": "reel_4_description",
      "label": "Descripcion",
      "default": "Descubre los blazers que estan dominando la temporada."
    }
  ],
  "presets": [
    {
      "name": "Social Commerce"
    }
  ]
}
{% endschema %}
