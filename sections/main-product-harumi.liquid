{% comment %}
  Mila Rosse - V3 Harumi Style Product Section
  - Stacked Desktop / Carousel Mobile
  - Sticky info panel
  - Minimalist uncolored aesthetic stars
  - Trust icons
  - Accordions
  - Recommendations
{% endcomment %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

  :root {
    --mr-cream: #FBF9F6;
    --mr-green: #1B4D3E;
    --mr-border: rgba(27, 77, 62, 0.15);
    /* Serif variable kept for legacy compatibility but NEVER used in this section */
    --mr-font-serif: 'Inter', sans-serif;
    --mr-font-sans: 'Inter', sans-serif;
  }

  /* ============================================================
     SECTION-SCOPED SERIF RESET
     Override any global theme Serif applied to headings.
     This block must stay at the top of the section styles.
  ============================================================ */
  .mr-product-harumi h1,
  .mr-product-harumi h2,
  .mr-product-harumi h3,
  .mr-product-harumi h4,
  .mr-product-harumi h5,
  .mr-product-harumi h6,
  .mr-product-harumi p,
  .mr-product-harumi span,
  .mr-product-harumi label,
  .mr-product-harumi button,
  .mr-product-harumi a,
  .mr-product-harumi li {
    font-family: 'Inter', sans-serif !important;
  }

  .mr-product-harumi {
    background-color: var(--mr-cream);
    color: var(--mr-green);
    font-family: var(--mr-font-sans);
    padding: 0;
    margin: 0;
  }

  .mr-product-harumi__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
    display: grid;
    grid-template-columns: 60% 40%;
    gap: 3rem;
  }

  /* MEDIA GALLERY (Desktop) */
  .mr-gallery {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .mr-gallery img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 4px;
    background: #f1ede6;
  }

  /* PRODUCT INFO (Sticky Desktop) */
  .mr-info-wrapper {
    position: sticky;
    top: 2rem;
    align-self: start;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    padding-right: 15px;
    padding-bottom: 2rem;
    scrollbar-width: thin;
    scrollbar-color: var(--mr-border) transparent;
  }
  .mr-info-wrapper::-webkit-scrollbar {
    width: 4px;
  }
  .mr-info-wrapper::-webkit-scrollbar-thumb {
    background-color: var(--mr-border);
    border-radius: 4px;
  }

  /* Minimalism aesthetic stars */
  .mr-aesthetic-stars {
    display: inline-flex;
    gap: 3px;
    margin-bottom: 1rem;
    align-items: center;
  }
  .mr-aesthetic-stars svg {
    width: 15px;
    height: 15px;
    fill: none;
    stroke: var(--mr-green);
    stroke-width: 1.5;
  }
  .mr-review-count {
    font-size: 0.8rem;
    margin-left: 6px;
    letter-spacing: 1px;
    opacity: 0.8;
  }

  /* ============================================================
     TYPOGRAPHY HIERARCHY
     Level 1 — Product Title
     Level 2 — Price
     Level 3 — UI Labels (TALLA, GUÍA DE TALLAS, tab buttons)
     Level 4 — Content subtitles (tab text, trust items)
  ============================================================ */

  /* Level 1: Product Title */
  .mr-product-title {
    font-family: 'Inter', sans-serif !important;
    font-size: clamp(1.7rem, 2.8vw, 2.6rem);
    margin: 0 0 0.6rem 0;
    color: var(--mr-green);
    line-height: 1.05;          /* Tight line-height for multi-line titles */
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;     /* Negative tracking on heavy weight looks premium */
  }

  /* Level 2: Price */
  .mr-product-price {
    font-family: 'Inter', sans-serif !important;
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: 0;
    margin-bottom: 2rem;
    font-style: normal;         /* Explicitly no italic */
  }

  /* Form & Variants */
  .mr-variant-selector {
    margin-bottom: 2rem;
  }
  .mr-variant-label-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
  }
  /* Level 3: UI Labels (TALLA, etc.) */
  .mr-variant-label {
    font-family: 'Inter', sans-serif !important;
    font-weight: 700;
    display: block;
    text-transform: uppercase;
    font-size: 0.72rem;          /* ~11.5px */
    letter-spacing: 1.8px;      /* Open tracking for small caps feel */
    color: var(--mr-green);
  }
  /* Level 3: Guía de tallas — same hierarchy as label */
  .mr-size-guide {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-decoration: underline;
    cursor: pointer;
    opacity: 0.65;
    text-transform: uppercase;
  }
  .mr-variant-options {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .mr-variant-pill {
    display: inline-block;
  }
  .mr-variant-pill input[type="radio"] {
    display: none;
  }
  .mr-variant-pill label {
    font-family: 'Inter', sans-serif !important;
    display: inline-block;
    padding: 10px 20px;
    border: 1px solid var(--mr-border);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    transition: all 0.2s ease;
    border-radius: 4px;
    background: transparent;
  }
  .mr-variant-pill input[type="radio"]:checked + label {
    background: var(--mr-green);
    color: var(--mr-cream);
    border-color: var(--mr-green);
  }

  /* Buttons */
  .mr-btn {
    width: 100%;
    background-color: var(--mr-green);
    color: #fff;
    border: 1px solid var(--mr-green);
    padding: 1.3rem;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.3s;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    display: block;
    text-align: center;
  }
  .mr-btn:hover {
    background-color: #123329;
    color: #fff;
  }

  /* Trust Icons */
  .mr-trust-icons {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-bottom: 3rem;
    padding: 1.5rem;
    background: rgba(27, 77, 62, 0.03);
    border-radius: 6px;
  }
  /* Level 4: Trust badge text */
  .mr-trust-item {
    font-family: 'Inter', sans-serif !important;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.75rem;          /* ~12px */
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
  }
  .mr-trust-item svg {
    flex-shrink: 0;
    width: 17px;
    height: 17px;
    fill: none;
    stroke: var(--mr-green);
    stroke-width: 1.5;
  }

  /* Tabs */
  .mr-tabs {
    border-top: 1px solid var(--mr-border);
    margin-bottom: 3rem;
    margin-top: 3rem;
  }
  .mr-tabs-header {
    display: flex;
    gap: 2rem;
    border-bottom: 1px solid var(--mr-border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .mr-tabs-header::-webkit-scrollbar { display: none; }
  /* Level 3: Tab buttons */
  .mr-tab-btn {
    font-family: 'Inter', sans-serif !important;
    background: none;
    border: none;
    padding: 1rem 0;
    font-size: 0.75rem;          /* ~12px — same tier as UI labels */
    font-weight: 700;
    color: var(--mr-green);
    opacity: 0.5;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    position: relative;
    white-space: nowrap;
    transition: opacity 0.2s;
  }
  .mr-tab-btn.active {
    opacity: 1;
  }
  .mr-tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--mr-green);
  }
  /* Level 4: Tab content body text */
  .mr-tab-content {
    font-family: 'Inter', sans-serif !important;
    display: none;
    padding: 1.5rem 0;
    font-size: 0.93rem;          /* ~15px */
    font-weight: 400;
    line-height: 1.75;
    color: rgba(27, 77, 62, 0.8);
  }
  .mr-tab-content.active {
    display: block;
  }

  /* Review Minimalist UI / Testimonials */
  .mr-pdp__testimonials {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--mr-border);
    font-family: 'Inter', sans-serif !important;
  }
  .mr-pdp__testimonials-title {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.8px;
  }
  .mr-pdp__testimonials-title {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--mr-text, #1a1a1a);
    margin: 0 0 15px;
  }
  .mr-pdp__testimonials-summary {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 20px;
  }
  .mr-pdp__testimonials-stars {
    display: flex;
    align-items: center;
    color: var(--mr-copper, #c97a44);
    font-size: 1.2rem;
    margin-bottom: 5px;
  }
  .mr-pdp__testimonials-stars .half { opacity: 0.5; }
  .mr-pdp__testimonials-score {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--mr-text-light, #666);
    margin-left: 10px;
  }
  .mr-pdp__testimonials-count {
    font-size: 0.75rem;
    color: var(--mr-text-light, #666);
    margin: 0;
  }
  .mr-pdp__testimonials-bars {
    max-width: 320px;
    margin: 0 auto 30px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mr-pdp__testimonials-bar-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.75rem;
    color: var(--mr-text-light, #666);
  }
  .mr-pdp__testimonials-bar-stars {
    color: var(--mr-copper, #c97a44);
    width: 60px;
    text-align: right;
    letter-spacing: 2px;
  }
  .mr-pdp__testimonials-bar-stars .empty { color: var(--mr-border, #e8e4de); }
  .mr-pdp__testimonials-bar-track {
    flex: 1;
    height: 8px;
    background: var(--mr-cream, #faf8f6);
    border-radius: 4px;
    overflow: hidden;
  }
  .mr-pdp__testimonials-bar-fill {
    height: 100%;
    background: var(--mr-dark-green, #1a472a);
    border-radius: 4px;
  }
  .mr-pdp__testimonials-bar-count {
    width: 30px;
    text-align: left;
  }
  .mr-pdp__testimonials-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 20px;
  }
  .mr-pdp__testimonials-btn {
    width: 100%;
    padding: 12px;
    border-radius: 30px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .mr-pdp__testimonials-btn--dark {
    background: #333333;
    color: #ffffff;
    border: none;
  }
  .mr-pdp__testimonials-btn--dark:hover { background: #000000; }
  .mr-pdp__testimonials-btn--light {
    background: #ffffff;
    color: var(--mr-text-light, #666);
    border: 1px solid var(--mr-border, #e8e4de);
  }
  .mr-pdp__testimonials-btn--light:hover { background: var(--mr-cream, #faf8f6); }

  /* Related Products */
  .mr-related-section {
    border-top: 1px solid var(--mr-border);
    margin-top: 2rem;
    padding: 5rem 2rem;
    background-color: #fff;
  }
  .mr-related-title {
    font-family: var(--mr-font-serif);
    font-size: 2rem;
    text-align: center;
    margin-bottom: 3rem;
    font-weight: 400;
    color: var(--mr-green);
  }
  .mr-related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .mr-related-product {
    text-decoration: none;
    color: var(--mr-green);
    group;
  }
  .mr-related-img-wrap {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    margin-bottom: 1.2rem;
    background: #f1ede6;
  }
  .mr-related-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .mr-related-product:hover .mr-related-img-wrap img {
    transform: scale(1.04);
  }
  .mr-related-info h4 {
    font-family: var(--mr-font-sans);
    font-weight: 400;
    font-size: 0.95rem;
    margin: 0 0 0.4rem 0;
  }
  .mr-related-info .price {
    font-family: var(--mr-font-serif);
    font-weight: 400;
    font-size: 1.1rem;
  }

  /* MOBILE RESPONSIVE */
  @media screen and (max-width: 989px) {
    .mr-product-harumi__container {
      grid-template-columns: 1fr;
      padding: 0;
      gap: 0;
    }
    
    .mr-gallery {
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }
    .mr-gallery::-webkit-scrollbar {
      display: none;
    }
    .mr-gallery img {
      width: 100vw;
      flex-shrink: 0;
      scroll-snap-align: start;
      border-radius: 0;
    }
    
    .mr-info-wrapper {
      position: relative;
      top: 0;
      max-height: none;
      padding: 2.5rem 1.5rem;
      overflow: visible;
    }
    
    .mr-related-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .mr-related-section {
      padding: 4rem 1.5rem;
    }
  }
</style>

<div class="mr-product-harumi">
  <div class="mr-product-harumi__container">
    
    <!-- LEFT: GALLERY -->
    <div class="mr-gallery">
      {% for media in product.media %}
        {% if media.media_type == 'image' %}
          <img src="{{ media | image_url: width: 1200 }}" alt="{{ media.alt | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        {% endif %}
      {% endfor %}
    </div>

    <!-- RIGHT: PRODUCT INFO -->
    <div class="mr-info-wrapper">
      
      <!-- 1. Minimalist Review UI / Testimonials (Moved to top) -->
      <div class="mr-pdp__testimonials" style="margin-top: 0; padding-top: 0; border-top: none; margin-bottom: 1rem;">
        <div class="mr-pdp__testimonials-summary" style="flex-direction: row; justify-content: flex-start; gap: 10px; margin-bottom: 0;">
          <div class="mr-pdp__testimonials-stars" style="margin-bottom: 0;">
            <span>★</span><span>★</span><span>★</span><span>★</span><span class="half">★</span>
          </div>
          <span class="mr-review-count" style="text-decoration: underline; cursor: pointer;">4.66 / 5 (458 reseñas)</span>
        </div>
      </div>

      <!-- 2. Title & Price -->
      <h1 class="mr-product-title">{{ product.title }}</h1>
      <div class="mr-product-price">{{ product.price | money }}</div>

      <!-- 3. Add to Cart Form & Variants -->
      {%- form 'product', product, id: 'product-form-harumi', class: 'form' -%}
        {% unless product.has_only_default_variant %}
          <div class="mr-variant-selector">
            {% for option in product.options_with_values %}
              <div class="mr-variant-label-container">
                <label class="mr-variant-label">{{ option.name }}</label>
                {% if option.name == 'Talla' or option.name == 'Size' or option.name == 'talla' %}
                  <span class="mr-size-guide">Guía de tallas</span>
                {% endif %}
              </div>
              <div class="mr-variant-options" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  <div class="mr-variant-pill">
                    <input type="radio" id="Option-{{ section.id }}-{{ option.name }}-{{ forloop.index0 }}" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}>
                    <label for="Option-{{ section.id }}-{{ option.name }}-{{ forloop.index0 }}">{{ value }}</label>
                  </div>
                {% endfor %}
              </div>
            {% endfor %}
          </div>
        {% endunless %}

        <input type="hidden" name="id" id="VariantId-{{ section.id }}" value="{{ product.selected_or_first_available_variant.id }}">
        
        <button type="submit" name="add" id="AddToCart-{{ section.id }}" class="mr-btn" {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
          {% if product.selected_or_first_available_variant.available %}
            AÑADIR A LA BOLSA
          {% else %}
            AGOTADO
          {% endif %}
        </button>
      {%- endform -%}

      <!-- 4. Trust Sidebar Icons -->
      <div class="mr-trust-icons">
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <span>En existencias, listo para enviar</span>
        </div>
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <span>Pago 100% encriptado y seguro</span>
        </div>
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>
          <span>Facturación electrónica disponible</span>
        </div>
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          <span>Envíos Rápidos en 48 horas</span>
        </div>
        <div class="mr-trust-item">
          <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"></polyline><polyline points="23 20 23 14 17 14"></polyline><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"></path></svg>
          <span>Política de Devolución extendida</span>
        </div>
      </div>

      <!-- 5. Description Tabs -->
      <div class="mr-tabs" id="ProductTabs-{{ section.id }}">
        <div class="mr-tabs-header">
          <button class="mr-tab-btn active" data-tab="detalles">Detalles</button>
          <button class="mr-tab-btn" data-tab="envio">Envío</button>
          <button class="mr-tab-btn" data-tab="devoluciones">Devoluciones</button>
        </div>
        
        <div class="mr-tab-content active" id="tab-detalles">
          {% if product.description != blank %}
            {{ product.description }}
          {% else %}
            <p>Un artículo de sastrería excepcional, diseñado meticulosamente para la mujer contemporánea. Confeccionado con técnicas artesanales y los mejores materiales del mercado para garantizar durabilidad, estructura y un ajuste sencillamente impecable.</p>
          {% endif %}
        </div>
        
        <div class="mr-tab-content" id="tab-envio">
          <p>Ofrecemos envíos a nivel nacional e internacional. Los pedidos se procesan en un plazo de 24 a 48 horas hábiles. Recibirás un número de seguimiento tan pronto como tu paquete haya sido despachado.</p>
        </div>
        
        <div class="mr-tab-content" id="tab-devoluciones">
          <p>Queremos que ames tu compra. Si no estás completamente satisfecha, aceptamos cambios y devoluciones dentro de los 30 días posteriores a la recepción, siempre y cuando el artículo esté sin usar y en su estado original.</p>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Related Products -->
<div class="mr-related-section">
  <h2 class="mr-related-title">Más para descubrir</h2>
  
  <product-recommendations class="mr-related-grid" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=4">
    {%- if recommendations.performed and recommendations.products_count > 0 -%}
      {% for recommendation in recommendations.products limit: 4 %}
        <a href="{{ recommendation.url }}" class="mr-related-product">
          <div class="mr-related-img-wrap">
            <img src="{{ recommendation.featured_media | image_url: width: 600 }}" alt="{{ recommendation.title | escape }}" loading="lazy">
          </div>
          <div class="mr-related-info">
            <h4>{{ recommendation.title }}</h4>
            <div class="price">{{ recommendation.price | money }}</div>
          </div>
        </a>
      {% endfor %}
    {%- endif -%}
  </product-recommendations>
</div>

<script type="application/json" id="ProductJson-{{ section.id }}">
  {{ product.variants | json }}
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Recommendations Script
    const handleRecommendations = () => {
      const recommendationsContainer = document.querySelector('product-recommendations');
      if (!recommendationsContainer) return;
      
      fetch(recommendationsContainer.dataset.url)
        .then(response => response.text())
        .then(text => {
          const html = document.createElement('div');
          html.innerHTML = text;
          const recommendations = html.querySelector('product-recommendations');
          
          if (recommendations && recommendations.innerHTML.trim().length) {
            recommendationsContainer.innerHTML = recommendations.innerHTML;
          }
        })
        .catch(e => {
          console.error('Error fetching recommendations:', e);
        });
    };
    handleRecommendations();

    // 2. Tabs Script
    const tabs = document.querySelectorAll('#ProductTabs-{{ section.id }} .mr-tab-btn');
    const contents = document.querySelectorAll('#ProductTabs-{{ section.id }} .mr-tab-content');
    
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));
        
        tab.classList.add('active');
        document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
      });
    });

    // 3. Variant Radio Logic
    const variantRadios = document.querySelectorAll('.mr-variant-selector input[type="radio"]');
    const variantHiddenInput = document.getElementById('VariantId-{{ section.id }}');
    const productJsonEl = document.getElementById('ProductJson-{{ section.id }}');
    const addToCartBtn = document.getElementById('AddToCart-{{ section.id }}');

    if (variantRadios.length > 0 && productJsonEl && variantHiddenInput) {
      const productVariants = JSON.parse(productJsonEl.innerHTML);

      variantRadios.forEach(radio => {
        radio.addEventListener('change', () => {
          // Get current selected options
          const selectedOptions = Array.from(document.querySelectorAll('.mr-variant-selector input[type="radio"]:checked')).map(el => el.value);
          
          // Find the matching variant
          const matchedVariant = productVariants.find(variant => {
            return selectedOptions.every((option, index) => {
              return variant.options[index] === option;
            });
          });

          if (matchedVariant) {
            variantHiddenInput.value = matchedVariant.id;
            
            // Update button state
            if (matchedVariant.available) {
              addToCartBtn.disabled = false;
              addToCartBtn.innerHTML = 'AÑADIR A LA BOLSA';
            } else {
              addToCartBtn.disabled = true;
              addToCartBtn.innerHTML = 'AGOTADO';
            }
          }
        });
      });
    }
  });
</script>

