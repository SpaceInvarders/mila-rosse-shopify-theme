<section class="mr-social">
  <div class="mr-social__container">
    <div class="mr-social__head">
      <div class="mr-intro__eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="mr-intro__title">{{ section.settings.title }}</h2>
      <div class="mr-intro__divider"></div>
      <p class="mr-intro__text">{{ section.settings.text }}</p>
    </div>

    <div class="mr-social__grid">

      <div class="mr-reel">
        <div class="mr-reel__embed-wrap">
          <iframe
            src="{{ section.settings.reel_1_url }}"
            class="mr-reel__embed"
            frameborder="0"
            scrolling="no"
            allowtransparency="true"
            allowfullscreen="true"
            loading="lazy"
          ></iframe>
        </div>
        <div class="mr-reel__caption">
          <h3 class="mr-reel__title">{{ section.settings.reel_1_title }}</h3>
          <p class="mr-reel__sub">{{ section.settings.reel_1_description }}</p>
        </div>
      </div>

      <div class="mr-reel">
        <div class="mr-reel__embed-wrap">
          <iframe
            src="{{ section.settings.reel_2_url }}"
            class="mr-reel__embed"
            frameborder="0"
            scrolling="no"
            allowtransparency="true"
            allowfullscreen="true"
            loading="lazy"
          ></iframe>
        </div>
        <div class="mr-reel__caption">
          <h3 class="mr-reel__title">{{ section.settings.reel_2_title }}</h3>
          <p class="mr-reel__sub">{{ section.settings.reel_2_description }}</p>
        </div>
      </div>

      <div class="mr-reel">
        <div class="mr-reel__embed-wrap">
          <iframe
            src="{{ section.settings.reel_3_url }}"
            class="mr-reel__embed"
            frameborder="0"
            scrolling="no"
            allowtransparency="true"
            allowfullscreen="true"
            loading="lazy"
          ></iframe>
        </div>
        <div class="mr-reel__caption">
          <h3 class="mr-reel__title">{{ section.settings.reel_3_title }}</h3>
          <p class="mr-reel__sub">{{ section.settings.reel_3_description }}</p>
        </div>
      </div>

      <div class="mr-reel">
        <div class="mr-reel__embed-wrap">
          <iframe
            src="{{ section.settings.reel_4_url }}"
            class="mr-reel__embed"
            frameborder="0"
            scrolling="no"
            allowtransparency="true"
            allowfullscreen="true"
            loading="lazy"
          ></iframe>
        </div>
        <div class="mr-reel__caption">
          <h3 class="mr-reel__title">{{ section.settings.reel_4_title }}</h3>
          <p class="mr-reel__sub">{{ section.settings.reel_4_description }}</p>
        </div>
      </div>

    </div>

    <div class="mr-products__cta-wrap">
      <a href="https://instagram.com/{{ settings.instagram_handle }}" target="_blank" rel="noopener" class="mr-btn mr-btn--solid">{{ section.settings.button_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Commerce",
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "INSTAGRAM"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Shop the Look"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Descripcion",
      "default": "Inspirate con nuestros looks en redes sociales."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del boton",
      "default": "Seguir @milarosse.studio"
    },
    {
      "type": "header",
      "content": "Reel 1"
    },
    {
      "type": "text",
      "id": "reel_1_url",
      "label": "URL Embed Instagram",
      "info": "Formato: https://www.instagram.com/p/POST_ID/embed/",
      "default": "https://www.instagram.com/p/DZXxrVeRG67/embed/"
    },
    {
      "type": "text",
      "id": "reel_1_title",
      "label": "Titulo",
      "default": "Gabán: Infinitas Posibilidades"
    },
    {
      "type": "textarea",
      "id": "reel_1_description",
      "label": "Descripcion",
      "default": "La prenda que transforma cualquier outfit y te hace lucir impecable en segundos."
    },
    {
      "type": "header",
      "content": "Reel 2"
    },
    {
      "type": "text",
      "id": "reel_2_url",
      "label": "URL Embed Instagram",
      "default": "https://www.instagram.com/p/DY-aLuOpJ4h/embed/"
    },
    {
      "type": "text",
